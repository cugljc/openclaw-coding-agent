{
  "name": "openclaw-coding-agent",
  "version": "1.0.0",
  "description": "Ultimate OpenClaw plugin: dispatch coding tasks to Cursor CLI, Claude Code, and Codex — cross-platform (Windows + macOS/Linux)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/index.js",
    "openclaw.plugin.json",
    "hooks/",
    "scripts/"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "sync-version": "node --input-type=commonjs -e \"const p=require('./package.json'),o=require('./openclaw.plugin.json');o.version=p.version;require('fs').writeFileSync('./openclaw.plugin.json',JSON.stringify(o,null,2)+'\\n')\"",
    "build": "npm run sync-version && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:openclaw",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:openclaw --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
